DJANGO_SECRET_KEY=<python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"로 생성한 값>
DJANGO_DEBUG=false

# 최초 관리자 계정(create_initial_admins) 비밀번호 — 하드코딩 금지, 배포 시에만 주입
ADMIN_INIT_PASSWORD=<초기 관리자 비밀번호, 생성 후 강제 변경됨>

DB_NAME=namingdb
DB_USER=namingadmin
DB_PASSWORD=<비밀번호>
DB_HOST=<RDS 엔드포인트>.rds.amazonaws.com
DB_SSL_REQUIRE=true

NEO4J_URI=bolt://neo4j:5
NEO4J_USER=neo4j
NEO4J_PASSWORD=<비밀번호>
NEO4J_DATABASE=neo4j

OPENAI_API_KEY=<KEY입력>
LAW_API_KEY=<KEY입력>
URIMALSAM_API_KEY=<KEY입력>

USE_S3=true
AWS_ACCESS_KEY_ID=<IAM 액세스 키>
AWS_SECRET_ACCESS_KEY=<IAM 시크릿 키>
AWS_STORAGE_BUCKET_NAME=<버킷명>
