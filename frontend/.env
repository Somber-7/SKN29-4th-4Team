# 백엔드 API 베이스 URL. 비워두면(또는 미설정) 상대경로 "/api"를 사용하며,
# 개발 서버에서는 vite.config.ts의 server.proxy가 http://localhost:8000(Django)으로 전달한다.
VITE_API_BASE_URL=

# FastAPI + Neo4j(작명 생성·채팅) 베이스 URL. 비워두면 상대경로 "/naming-api"를 사용하며,
# 개발 서버에서는 vite.config.ts의 server.proxy가 http://localhost:8001(FastAPI)으로 전달한다.
VITE_NAMING_API_BASE_URL=

# admin.ts/support.ts가 아직 이 전역 플래그를 쓴다(names/auth처럼 도메인별 플래그로
# 분리되지 않음) — false로 관리자 페이지·FAQ·공지·문의·heartbeat를 전부 실 API로 연동한다.
# Vite가 --mode 무관하게 항상 로드하는 파일이라(.env), 사용자 빌드·관리자 빌드(--mode admin)
# 둘 다에 적용된다.
VITE_USE_MOCK=false

# 인증 도메인 mock 스위치. 기본값 false = Django 세션 API 사용(이미 실연동).
VITE_USE_MOCK_AUTH=false
